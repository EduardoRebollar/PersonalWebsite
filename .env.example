# Vercel AI Gateway key — powers the LA History demo's Socratic tutor,
# concept-map evaluator, hint generator, and insight endpoint at
# /api/la-history/*. Without this set, those routes return 5xx but the
# rest of the portfolio works fine.
#
# To get one: vercel link, then `vercel env add AI_GATEWAY_API_KEY` and
# `vercel env pull .env.local` (install the CLI with `npm i -g vercel`).
AI_GATEWAY_API_KEY=
